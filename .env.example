# Prisma Embedded Codes Docker environment example.
# Copy to .env before running docker compose:
#   Copy-Item .env.example .env
#
# Generate JWT_PRIVATE_KEY, JWT_PUBLIC_KEY, CSRF_SECRET, and FIELD_ENCRYPTION_KEY with:
#   cd backend
#   node generate-keys.js

# Frontend build-time API paths. Keep these relative when frontend and backend run behind Nginx.
VITE_API_BASE_URL=/api/v1
VITE_RESUME_API_BASE_URL=/api/resume
# Optional. Leave blank for same-origin WebSocket in Docker.
VITE_WS_BASE_URL=

# Published frontend port on the Docker host.
FRONTEND_PORT=8080

# PostgreSQL container settings.
POSTGRES_DB=prisma_embedded_codes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_postgres_password

# Redis container setting.
REDIS_PASSWORD=change_this_redis_password

# Backend runtime settings.
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Derived Docker service URLs. Compose sets these for the backend automatically;
# keep them here for local scripts or non-Compose deployments.
DATABASE_URL=postgresql://postgres:change_this_postgres_password@postgres:5432/prisma_embedded_codes?schema=public
DATABASE_REPLICA_URL=postgresql://postgres:change_this_postgres_password@postgres:5432/prisma_embedded_codes?schema=public
REDIS_URL=redis://:change_this_redis_password@redis:6379/0

# Paste generated values from backend/generate-keys.js.
JWT_PRIVATE_KEY=replace_with_generated_base64_private_key
JWT_PUBLIC_KEY=replace_with_generated_base64_public_key
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800
CSRF_SECRET=replace_with_generated_64_char_hex_secret
FIELD_ENCRYPTION_KEY=replace_with_generated_64_char_hex_key

# Email. RESEND_API_KEY can stay re_mock_key for local smoke tests.
RESEND_API_KEY=re_mock_key
EMAIL_FROM=noreply@example.com

# Optional OAuth providers.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional AI integrations. Never expose these with VITE_ prefixes.
GROQ_API_KEY=
GROQ_API_KEY2=
GROQ_API_KEY3=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile
HUGGINGFACE_API_KEY=
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional production bootstrap admin.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=System Administrator

# Security hardening.
BCRYPT_ROUNDS=12
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_MINUTES=30

# This project currently has Prisma schema but no committed migrations.
# Leave true for first Docker bootstrap; switch to migrations for mature production releases.
PRISMA_DB_PUSH=true
# Set true only for intentional destructive schema changes, such as dropping disabled features.
PRISMA_DB_PUSH_ACCEPT_DATA_LOSS=false
