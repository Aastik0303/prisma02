{
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://prisma02-production.up.railway.app/api/v1/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
