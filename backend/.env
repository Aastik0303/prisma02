# Redis Config
REDIS_URL="redis://:redispassword@localhost:6379/0"

# JWT — ES256 Keys (generate using openssl ecparam -name prime256v1 -genkey)
JWT_PRIVATE_KEY_BASE64=MIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQghl45owJLdMmVnzR6HoTt+yk63gUhFeGiuS+qb1zvXoGhRANCAAQCpQVdzfJJrlYbJXaS/ucutRrGucJpLv/xrhqVfcFzvhkOQ5usXQcqeldfNSW3fV95PK5kXYfbefWzwgP2ATpf
JWT_PUBLIC_KEY_BASE64=MFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAEAqUFXc3ySa5WGyV2kv7nLrUaxrnCaS7/8a4alX3Bc74ZDkObrF0HKnpXXzUlt31feTyuZF2H23n1s8ID9gE6Xw==
