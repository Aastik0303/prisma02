# Backend environment example.
# Copy to backend/.env for local development, or use the root .env with docker compose.
# Generate JWT_PRIVATE_KEY, JWT_PUBLIC_KEY, CSRF_SECRET, and FIELD_ENCRYPTION_KEY with:
#   node generate-keys.js

NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# Local host URLs for non-Docker development.
# Inside Docker Compose, use hostnames postgres and redis instead of localhost.
POSTGRES_PASSWORD=change_this_postgres_password
DATABASE_URL=postgresql://postgres:change_this_postgres_password@localhost:5432/prisma_auth?schema=public
DATABASE_REPLICA_URL=postgresql://postgres:change_this_postgres_password@localhost:5432/prisma_auth?schema=public
REDIS_PASSWORD=change_this_redis_password
REDIS_URL=redis://:change_this_redis_password@localhost:6379/0

JWT_PRIVATE_KEY=replace_with_generated_base64_private_key
JWT_PUBLIC_KEY=replace_with_generated_base64_public_key
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800
CSRF_SECRET=replace_with_generated_64_char_hex_secret
FIELD_ENCRYPTION_KEY=replace_with_generated_64_char_hex_key

RESEND_API_KEY=re_mock_key
EMAIL_FROM=noreply@example.com
EMAIL_PROVIDER=resend
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GROQ_API_KEY=
GROQ_API_KEY2=
GROQ_API_KEY3=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile
HUGGINGFACE_API_KEY=
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=System Administrator

BCRYPT_ROUNDS=12
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_MINUTES=30
