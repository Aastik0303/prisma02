# Server Config
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,https://prismaembedded.codes,https://www.prismaembedded.codes

# Database Config (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prisma_auth?schema=public"
DATABASE_REPLICA_URL="postgresql://postgres:postgres@localhost:5432/prisma_auth?schema=public"

# Redis Config
REDIS_URL="redis://:redispassword@localhost:6379/0"

# JWT — ES256 Keys (generate using openssl ecparam -name prime256v1 -genkey)
# These should be base64-encoded strings of the PEM private and public key files.
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_ACCESS_EXPIRY=900           # 15 minutes (in seconds)
JWT_REFRESH_EXPIRY=604800       # 7 days (in seconds)

# CSRF Secret (64-char random hex string)
CSRF_SECRET=

# Resend Email Config
RESEND_API_KEY=re_example
EMAIL_FROM=noreply@prismaembedded.codes

# OAuth Credentials
GOOGLE_CLIENT_ID=google-client-id
GOOGLE_CLIENT_SECRET=google-client-secret
GITHUB_CLIENT_ID=github-client-id
GITHUB_CLIENT_SECRET=github-client-secret

# Sensitive field encryption key (32-byte hex key for encrypting secrets like OAuth tokens)
FIELD_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Security Hardening
BCRYPT_ROUNDS=12
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_MINUTES=30
